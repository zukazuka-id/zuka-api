# ─────────────────────────────────────────────────────────────────
# ZUKA API — Staging Environment Template
# Copy this file to .env on the server and fill in the values.
# NEVER commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────

# Database (Supabase PostgreSQL — can use same or separate project)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=[generate-a-random-32-char-string]
BETTER_AUTH_URL=https://staging-api.zuka.plus

# Server
PORT=3457
NODE_ENV=staging

# CORS origins (comma-separated — include local dev origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:7490,https://staging-member.zuka.plus,https://staging-merchant.zuka.plus

# DB connection pool (lower for shared VM)
DB_POOL_MAX=3

# OTP bypass — always use email in staging
OTP_BYPASS_EMAIL=zuka.plus.app@gmail.com

# Email sending (Resend)
# RESEND_API_KEY=re_xxxxx

# Sentry
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging

# Admin API key
ADMIN_API_KEY=[generate-a-random-secret]

# Allow unverified subscription create (staging only)
ALLOW_UNVERIFIED_SUBSCRIPTION_CREATE=true
