# Environment
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
BETTER_AUTH_SECRET=[GENERATE-RANDOM-32-CHAR]
BETTER_AUTH_URL=http://localhost:3456

# Server
PORT=3456
NODE_ENV=development

# CORS origins (comma-separated) — add all client app origins here
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7490,http://localhost:7492

# DB connection pool
# DB_POOL_MAX=10

# OTP bypass email (for production testing — sends all OTPs here)
# OTP_BYPASS_EMAIL=zuka.plus.app@gmail.com

# Email sending via Resend (for OTP bypass)
# RESEND_API_KEY=re_xxxxx

# Sentry error tracking
# SENTRY_DSN=

# Payment (TBD)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=

# Storage (Supabase)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
