# ─────────────────────────────────────────────────────────────────
# ZUKA API — Production Environment Template
# Copy this file to .env on the server and fill in the values.
# NEVER commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=[generate-a-random-32-char-string]
BETTER_AUTH_URL=https://api.zuka.plus

# Server
PORT=3456
NODE_ENV=production

# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://zuka.plus,https://member.zuka.plus,https://merchant.zuka.plus,https://admin.zuka.plus

# DB connection pool
DB_POOL_MAX=5

# OTP bypass email for production testing
OTP_BYPASS_EMAIL=zuka.plus.app@gmail.com

# Email sending (Resend)
# RESEND_API_KEY=re_xxxxx

# Sentry error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# Payment (Midtrans)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=

# Storage (Supabase)
# SUPABASE_URL=https://nrxeewkonnpztukubgwj.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Image upload (ImageKit)
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=

# Admin API key (for admin routes)
ADMIN_API_KEY=[generate-a-random-secret]

# Cron job security
# CRON_SECRET=
